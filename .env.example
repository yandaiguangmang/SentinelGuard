# ====================== SentinelGuard 网页恶意检测 ======================
# 主机地址，例如：0.0.0.0 或 127.0.0.1
HOST=0.0.0.0
# 端口，默认为 5000
PORT=5000

# ======================= 深度研判（可选） =======================
# 如果只做静态/页面检测，可以保持 False
ENABLE_DEEP_ANALYSIS=True

# ======================= 深度研判角色模型（推荐按角色匹配最擅长的模型） =======================
# 主持人：中文统筹、收敛观点、主持会诊
DETECTION_HOST_API_KEY=sk-hFs40fFuY5B9HkA76sD8R9P60uxYUQIuI7LEYfjxz0tMwG1N
DETECTION_HOST_BASE_URL=https://api.chatanywhere.tech/v1
DETECTION_HOST_MODEL_NAME=gpt-5

# 静态分析员：适合规则推理、证据归纳、漏洞/钓鱼线索拆解
DETECTION_STATIC_API_KEY=sk-hFs40fFuY5B9HkA76sD8R9P60uxYUQIuI7LEYfjxz0tMwG1N
DETECTION_STATIC_BASE_URL=https://api.chatanywhere.tech/v1
DETECTION_STATIC_MODEL_NAME=gemini-2.5-pro

# 行为分析员：适合长上下文页面行为、跳转链、表单/下载行为分析
DETECTION_BEHAVIOR_API_KEY=sk-hFs40fFuY5B9HkA76sD8R9P60uxYUQIuI7LEYfjxz0tMwG1N
DETECTION_BEHAVIOR_BASE_URL=https://api.chatanywhere.tech/v1
DETECTION_BEHAVIOR_MODEL_NAME=gemini-2.5-flash

# 情报分析员：适合跨源知识整合、威胁归因、背景情报总结
DETECTION_INTEL_API_KEY=sk-hFs40fFuY5B9HkA76sD8R9P60uxYUQIuI7LEYfjxz0tMwG1N
DETECTION_INTEL_BASE_URL=https://api.chatanywhere.tech/v1
DETECTION_INTEL_MODEL_NAME=gpt-5

# 处置建议员：适合快速生成明确、可执行的处置建议
DETECTION_ADVICE_API_KEY=sk-hFs40fFuY5B9HkA76sD8R9P60uxYUQIuI7LEYfjxz0tMwG1N
DETECTION_ADVICE_BASE_URL=https://api.chatanywhere.tech/v1
DETECTION_ADVICE_MODEL_NAME=gpt-5.4-mini

# ======================= 代理 / VPN 节点（仅网页抓取可选） =======================
# 如果访问可疑网址需要经过代理，请在这里填入
# 例如：http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
# 注意：当前深度研判的大语言模型调用保持直连原网络，不会继承这里的代理配置
DETECTION_HTTP_PROXY=http://10.250.167.176:7890
DETECTION_HTTPS_PROXY=https://10.250.167.176:7890

# ======================= 网页抓取参数 =======================
DETECTION_REPORT_DIR=sentinel_reports
DETECTION_TIMEOUT_SECONDS=6
DETECTION_USER_AGENT=SentinelGuard/1.0

# ======================= APK 动态分析（Android Studio 模拟器） =======================
# 若 adb 已加入 PATH 可留空；否则填写 adb.exe 的完整路径
ADB_PATH=C:\Users\lenovo\AppData\Local\Android\Sdk\platform-tools\adb.exe
# 动态沙箱窗口时长（秒）
APK_DYNAMIC_RUNTIME_WINDOW_SECONDS=12
